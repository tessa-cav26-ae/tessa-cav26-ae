dtmc

const double p1=0.4;
const double p2=0.5;

const int N;
const int N1 = N;
const int N2 = N;

module queue1
    pos1 : [0..N1] init 0;
    [step] pos1 < N1 -> p1: (pos1'=pos1+1) + 1-p1: (pos1'=pos1);
    [step] pos1 = N1 -> 1: (pos1'=pos1);
endmodule

module queue2=queue1[pos1=pos2,p1=p2,N1=N2] endmodule

label "target" = pos1=N1 & (pos2 < N2);


